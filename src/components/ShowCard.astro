---
interface Props {
  day: string;
  mon: string;
  year: string;
  venue: string;
  city: string;
  time: string;
  label: string;
  href: string;
  maps: string;
  cal: string;
  isUpcoming: boolean;
}

const { day, mon, year, venue, city, time, label, href, maps, cal, isUpcoming } = Astro.props;
---

<div class="show-card" data-event-row>
  <div class="show-card__date">
    <div class="show-card__day">{day}</div>
    <div class="show-card__mon">{mon}</div>
    <div class="show-card__year">{year}</div>
  </div>
  <div class="show-card__info">
    <div class="show-card__venue">{venue}</div>
    <div class="show-card__meta">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#C47A2C" stroke-width="2" aria-hidden="true">
        <path d="M12 21s7-6.5 7-12a7 7 0 1 0-14 0c0 5.5 7 12 7 12z"></path>
        <circle cx="12" cy="9" r="2.4"></circle>
      </svg>
      {city} &middot; {time}
    </div>
  </div>
  <div class="show-card__actions" data-actions>
    <a href={maps} target="_blank" rel="noopener" title="Google Maps" class="show-card__icon-btn">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 21s7-6.5 7-12a7 7 0 1 0-14 0c0 5.5 7 12 7 12z"></path>
        <circle cx="12" cy="9" r="2.4"></circle>
      </svg>
    </a>
    <a href={cal} target="_blank" rel="noopener" title="Add to Calendar" class="show-card__icon-btn">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="3" y="5" width="18" height="16" rx="2"></rect>
        <path d="M3 9h18M8 3v4M16 3v4"></path>
      </svg>
    </a>
    <a
      href={href}
      class:list={['show-card__cta', { 'show-card__cta--past': !isUpcoming }]}
    >
      {label}
    </a>
  </div>
</div>

<style>
  .show-card {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 26px;
    align-items: center;
    background: var(--color-bg-elevated);
    border: 1px solid rgba(244, 233, 216, 0.08);
    border-left: 3px solid var(--color-accent-dark);
    border-radius: 3px;
    padding: 22px 28px;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .show-card:hover {
    border-color: rgba(196, 122, 44, 0.5);
    background: var(--color-bg-hover);
  }

  .show-card__date {
    text-align: center;
    border-right: 1px solid rgba(244, 233, 216, 0.1);
    padding-right: 18px;
  }

  .show-card__day {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 28px;
    line-height: 1;
    color: var(--color-accent-light);
  }

  .show-card__mon {
    font-family: var(--font-display);
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-top: 4px;
  }

  .show-card__year {
    font-size: 11px;
    color: var(--color-text-dim);
    margin-top: 2px;
  }

  .show-card__venue {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(19px, 2.2vw, 25px);
    text-transform: uppercase;
    color: var(--color-text);
  }

  .show-card__meta {
    display: flex;
    align-items: center;
    gap: 7px;
    color: var(--color-text-muted);
    font-size: 14px;
    margin-top: 5px;
  }

  .show-card__actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .show-card__icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(244, 233, 216, 0.18);
    border-radius: 2px;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .show-card__icon-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-light);
  }

  .show-card__cta {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-bg);
    background: linear-gradient(135deg, var(--color-accent-light), var(--color-accent-dark));
    padding: 13px 24px;
    border-radius: 2px;
    text-decoration: none;
    white-space: nowrap;
  }

  .show-card__cta--past {
    color: var(--color-text);
    background: rgba(244, 233, 216, 0.14);
  }

  @media (max-width: 768px) {
    .show-card {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 20px;
    }

    .show-card__date {
      display: flex;
      align-items: baseline;
      gap: 10px;
      text-align: left;
      border-right: none;
      padding-right: 0;
      border-bottom: 1px solid rgba(244, 233, 216, 0.1);
      padding-bottom: 14px;
    }

    .show-card__actions {
      flex-wrap: wrap;
    }
  }
</style>
