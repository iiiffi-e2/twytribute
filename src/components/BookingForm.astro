<section class="booking-form" data-booking-form>
  <div class="booking-form__success" data-booking-success hidden>
    <div class="booking-form__success-icon" aria-hidden="true">
      <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#0D0D0D" stroke-width="2.5">
        <path d="M5 12l4 4 10-10"></path>
      </svg>
    </div>
    <h3 class="booking-form__success-title">Inquiry Sent &mdash; Thank You!</h3>
    <p class="booking-form__success-text">
      We&rsquo;ll get back to you within 24&ndash;48 hours. For anything urgent, reach us at
      <a href="mailto:sdmbooking@yahoo.com">sdmbooking@yahoo.com</a>.
    </p>
  </div>

  <form class="booking-form__form" data-booking-form-el>
    <div class="booking-form__honeypot" aria-hidden="true">
      <label for="booking-website">Website</label>
      <input
        id="booking-website"
        class="twy-field"
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
      />
    </div>

    <div class="booking-form__grid">
      <div>
        <label class="booking-form__label" for="booking-name">Name *</label>
        <input
          id="booking-name"
          class="twy-field"
          name="name"
          type="text"
          placeholder="Your name"
          required
        />
      </div>

      <div>
        <label class="booking-form__label" for="booking-org">Organization</label>
        <input
          id="booking-org"
          class="twy-field"
          name="org"
          type="text"
          placeholder="Company / venue (optional)"
        />
      </div>

      <div>
        <label class="booking-form__label" for="booking-phone">Phone *</label>
        <input
          id="booking-phone"
          class="twy-field"
          name="phone"
          type="tel"
          placeholder="(000) 000-0000"
          required
        />
      </div>

      <div>
        <label class="booking-form__label" for="booking-email">Email *</label>
        <input
          id="booking-email"
          class="twy-field"
          name="email"
          type="email"
          placeholder="you@email.com"
          required
        />
      </div>

      <div>
        <label class="booking-form__label" for="booking-date">Event Date</label>
        <input id="booking-date" class="twy-field twy-field--date" name="date" type="date" />
      </div>

      <div>
        <label class="booking-form__label" for="booking-location">Location</label>
        <input
          id="booking-location"
          class="twy-field"
          name="location"
          type="text"
          placeholder="City, venue or address"
        />
      </div>

      <div class="booking-form__full">
        <label class="booking-form__label" for="booking-audience">Estimated Audience Size</label>
        <input
          id="booking-audience"
          class="twy-field"
          name="audienceSize"
          type="text"
          placeholder="e.g. 150–300 guests"
        />
      </div>

      <div class="booking-form__full">
        <label class="booking-form__label" for="booking-message">Message</label>
        <textarea
          id="booking-message"
          class="twy-field"
          name="message"
          rows="4"
          placeholder="Tell us about your event…"
        ></textarea>
      </div>
    </div>

    <div class="booking-form__footer">
      <div class="booking-form__error" data-booking-error hidden>
        <p data-booking-error-msg>Something went wrong. Please try again.</p>
      </div>

      <div class="booking-form__actions">
        <p class="booking-form__hint">We typically reply within 24&ndash;48 hours.</p>
        <button type="submit" class="btn-primary booking-form__submit">Send Inquiry</button>
      </div>
    </div>
  </form>
</section>

<script src="../scripts/booking-form.ts"></script>

