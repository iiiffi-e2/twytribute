---
export interface GalleryItem {
  _id: string;
  imageUrl: string;
  alt: string;
  category: string;
  label: string;
}

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;

const CAT_DEFS = [
  { key: 'all', label: 'All' },
  { key: 'live', label: 'Live Shows' },
  { key: 'bts', label: 'Behind The Scenes' },
  { key: 'crowd', label: 'Crowd' },
  { key: 'venues', label: 'Venues' },
];
---

<section class="gallery-grid" data-gallery-root>
  <h2 class="gallery-grid__title">Photo Gallery</h2>

  <div class="gallery-grid__filters" role="group" aria-label="Gallery category">
    {
      CAT_DEFS.map((cat) => (
        <button
          type="button"
          class:list={[
            'gallery-grid__filter-btn',
            { 'gallery-grid__filter-btn--active': cat.key === 'all' },
          ]}
          data-gallery-filter={cat.key}
        >
          {cat.label}
        </button>
      ))
    }
  </div>

  <div class="gallery-grid__grid" data-gallery>
    {
      items.map((item) => (
        <div
          class="gallery-grid__item"
          data-zoom
          data-gallery-item
          data-category={item.category}
          data-gallery-src={item.imageUrl}
        >
          <img
            src={item.imageUrl}
            alt={item.alt}
            class="gallery-grid__img"
            loading="lazy"
            data-zoom-img
          />
          <span class="gallery-grid__label">{item.label}</span>
        </div>
      ))
    }
  </div>

  <div class="gallery-lightbox" data-gallery-lightbox hidden>
    <button type="button" class="gallery-lightbox__close" data-gallery-lightbox-close aria-label="Close">
      &times;
    </button>
    <img src="" alt="" class="gallery-lightbox__img" data-gallery-lightbox-img />
  </div>
</section>

<script src="../scripts/gallery-filter.ts"></script>

<style>
  .gallery-grid {
    padding: 60px 5vw 90px;
    background: var(--color-bg-elevated);
  }

  .gallery-grid__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 4vw, 48px);
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0 0 28px;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }

  .gallery-grid__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 34px;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }

  .gallery-grid__filter-btn {
    font-family: var(--font-display);
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 10px 20px;
    border: 1px solid rgba(244, 233, 216, 0.18);
    border-radius: 2px;
    cursor: pointer;
    color: var(--color-text-muted);
    background: transparent;
    transition: all 0.2s ease;
  }

  .gallery-grid__filter-btn--active {
    color: var(--color-bg);
    background: linear-gradient(135deg, var(--color-accent-light), var(--color-accent-dark));
    border-color: transparent;
  }

  .gallery-grid__grid {
    columns: 3;
    column-gap: 14px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .gallery-grid__item {
    break-inside: avoid;
    margin-bottom: 14px;
    overflow: hidden;
    border-radius: 3px;
    cursor: pointer;
    position: relative;
  }

  .gallery-grid__item[hidden] {
    display: none;
  }

  .gallery-grid__img {
    width: 100%;
    display: block;
    transition: transform 0.6s ease;
  }

  .gallery-grid__item:hover .gallery-grid__img {
    transform: scale(1.07);
  }

  .gallery-grid__label {
    position: absolute;
    left: 12px;
    bottom: 12px;
    font-family: var(--font-display);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text);
    background: rgba(13, 13, 13, 0.6);
    padding: 5px 10px;
    border-radius: 2px;
    opacity: 0.9;
  }

  .gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(8, 8, 8, 0.94);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5vw;
    cursor: zoom-out;
  }

  .gallery-lightbox[hidden] {
    display: none;
  }

  .gallery-lightbox__img {
    max-width: 92vw;
    max-height: 88vh;
    border-radius: 4px;
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.7);
  }

  .gallery-lightbox__close {
    position: fixed;
    top: 24px;
    right: 28px;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid rgba(244, 233, 216, 0.3);
    background: rgba(13, 13, 13, 0.6);
    color: var(--color-text);
    font-size: 22px;
    cursor: pointer;
    z-index: 2001;
    line-height: 1;
    padding: 0;
  }

  @media (max-width: 900px) {
    .gallery-grid__grid {
      columns: 2;
    }
  }

  @media (max-width: 600px) {
    .gallery-grid__grid {
      columns: 1;
    }
  }
</style>
