<section class="contact-form" data-contact-form>
  <div class="contact-form__success" data-contact-success hidden>
    <div class="contact-form__success-icon" aria-hidden="true">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#0D0D0D" stroke-width="2.5">
        <path d="M5 12l4 4 10-10"></path>
      </svg>
    </div>
    <h3 class="contact-form__success-title">Message Sent!</h3>
    <p class="contact-form__success-text">
      Thanks for reaching out &mdash; we&rsquo;ll get back to you soon.
    </p>
  </div>

  <form class="contact-form__form" data-contact-form-el>
    <div class="contact-form__fields">
      <div class="contact-form__honeypot" aria-hidden="true">
        <label for="contact-website">Website</label>
        <input
          id="contact-website"
          class="twy-field"
          type="text"
          name="website"
          tabindex="-1"
          autocomplete="off"
        />
      </div>

      <div>
        <label class="contact-form__label" for="contact-name">Name *</label>
        <input
          id="contact-name"
          class="twy-field"
          name="name"
          type="text"
          placeholder="Your name"
          required
        />
      </div>

      <div>
        <label class="contact-form__label" for="contact-email">Email *</label>
        <input
          id="contact-email"
          class="twy-field"
          name="email"
          type="email"
          placeholder="you@email.com"
          required
        />
      </div>

      <div>
        <label class="contact-form__label" for="contact-message">Message *</label>
        <textarea
          id="contact-message"
          class="twy-field"
          name="message"
          rows="5"
          placeholder="How can we help?"
          required
        ></textarea>
      </div>

      <div class="contact-form__error" data-contact-error hidden>
        <p data-contact-error-msg>Something went wrong. Please try again.</p>
      </div>

      <button type="submit" class="btn-primary contact-form__submit">Send Message</button>
    </div>
  </form>
</section>

<script src="../scripts/contact-form.ts"></script>

