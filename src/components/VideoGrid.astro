---
export interface VideoItem {
  _id: string;
  title: string;
  tag: string;
  youtubeId?: string;
  posterUrl?: string;
}

interface Props {
  videos: VideoItem[];
}

const { videos } = Astro.props;
const DEFAULT_POSTER = '/assets/twy-live1.jpg';
---

<section class="video-grid-section">
  <div class="video-grid-section__inner">
    <div class="video-grid-section__header">
      <h2 class="video-grid-section__title">Performance Videos</h2>
      <a
        href="https://www.instagram.com/texaswhiskeyandyou"
        target="_blank"
        rel="noopener noreferrer"
        class="video-grid-section__link"
      >
        More on Instagram &rarr;
      </a>
    </div>

    <div class="video-grid" data-video-grid>
      {
        videos.map((video) => {
          const poster = video.posterUrl || DEFAULT_POSTER;
          const youtubeId = video.youtubeId?.trim() ?? '';

          return (
            <div
              class="video-grid__card"
              data-vid
              data-video-player
              data-youtube-id={youtubeId}
              data-video-title={video.title}
            >
              <button
                type="button"
                class="video-grid__poster"
                data-video-poster
                aria-label={`Play ${video.title}`}
              >
                <img
                  src={poster}
                  alt=""
                  class="video-grid__poster-img"
                  data-vid-img
                  loading="lazy"
                />
                <div class="video-grid__overlay"></div>
                <div class="video-grid__play-wrap">
                  <div class="video-grid__play-btn" data-vid-play aria-hidden="true">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="#F4E9D8">
                      <path d="M8 5v14l11-7z"></path>
                    </svg>
                  </div>
                </div>
                <div class="video-grid__meta">
                  <div class="video-grid__tag">{video.tag}</div>
                  <div class="video-grid__video-title">{video.title}</div>
                </div>
              </button>
              <div class="video-grid__embed" data-video-embed hidden></div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<script src="../scripts/video-player.ts"></script>

<style>
  .video-grid-section {
    padding: 80px 5vw;
    background: var(--color-bg);
  }

  .video-grid-section__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .video-grid-section__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 40px;
  }

  .video-grid-section__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 4vw, 48px);
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0;
  }

  .video-grid-section__link {
    font-family: var(--font-display);
    font-size: 14px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(196, 122, 44, 0.4);
    padding-bottom: 4px;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .video-grid__card {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 5px;
    overflow: hidden;
    border: 1px solid rgba(244, 233, 216, 0.08);
  }

  .video-grid__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    border: none;
    cursor: pointer;
    background: none;
  }

  .video-grid__poster[hidden] {
    display: none;
  }

  .video-grid__poster-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .video-grid__card:hover .video-grid__poster-img {
    transform: scale(1.06);
  }

  .video-grid__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(13, 13, 13, 0.1), rgba(13, 13, 13, 0.75));
  }

  .video-grid__play-wrap {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .video-grid__play-btn {
    width: 66px;
    height: 66px;
    border-radius: 50%;
    background: rgba(13, 13, 13, 0.55);
    border: 1.5px solid rgba(244, 233, 216, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s ease;
  }

  .video-grid__card:hover .video-grid__play-btn {
    transform: scale(1.1);
  }

  .video-grid__meta {
    position: absolute;
    left: 20px;
    bottom: 18px;
    right: 20px;
    text-align: left;
  }

  .video-grid__tag {
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-light);
    margin-bottom: 5px;
  }

  .video-grid__video-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .video-grid__embed {
    position: absolute;
    inset: 0;
  }

  .video-grid__embed[hidden] {
    display: none;
  }

  @media (max-width: 700px) {
    .video-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
